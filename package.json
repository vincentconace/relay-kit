{
  "name": "relay-kit",
  "version": "0.1.0",
  "description": "MASD (Multi-Agent Spec Development) framework for Claude: 6 specialized agents, 7 slash commands, per-feature folders paired with git branches, persistent project memory, and one-command install + self-update.",
  "license": "MIT",
  "bin": {
    "relay-kit": "./install.sh",
    "relay-kit-update": "./update.sh"
  },
  "scripts": {
    "install:local": "bash ./install.sh",
    "update:local": "bash ./update.sh",
    "uninstall:local": "bash ./uninstall.sh"
  },
  "keywords": [
    "claude",
    "agents",
    "masd",
    "spec-driven",
    "multi-agent",
    "antigravity",
    "claude-code",
    "cowork"
  ],
  "files": [
    "install.sh",
    "install.ps1",
    "update.sh",
    "uninstall.sh",
    "commands",
    "agents",
    "templates",
    "memory",
    "README.md",
    "INSTALL.md",
    "DISTRIBUTION.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=14"
  }
}
